# =========================================================================
# DATABASE & SYSTEM CONFIGURATION
# =========================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"
AUTH_SECRET="ganti_dengan_random_secret_min_32_karakter"
NEXTAUTH_URL="http://localhost:3000"

# =========================================================================
# MANDIRI MERCHANT QRIS INTEGRATION SETTINGS (New)
# =========================================================================
# Feature Flag: Mengaktifkan atau menonaktifkan metode pembayaran Mandiri QRIS (true/false)
MANDIRI_PAYMENT_ENABLED=false

# Environment: 'sandbox' atau 'production'
MANDIRI_ENV=sandbox

# API Base URL & Endpoints
MANDIRI_BASE_URL=https://api-sandbox.mandiri.co.id
MANDIRI_TOKEN_URL=https://api-sandbox.mandiri.co.id/oauth/token
MANDIRI_CREATE_QRIS_PATH=/v1.0/qr/qr-mpm-generate
MANDIRI_INQUIRY_PATH=/v1.0/qr/qr-mpm-query
MANDIRI_CANCEL_PATH=/v1.0/qr/qr-mpm-cancel
MANDIRI_REFUND_PATH=/v1.0/qr/qr-mpm-refund

# Merchant & Channel Credentials
MANDIRI_MERCHANT_ID=MID123456789
MANDIRI_CLIENT_ID=CID-jstore-sandbox-key
MANDIRI_CLIENT_SECRET=SEC-jstore-sandbox-secret
MANDIRI_TERMINAL_ID=TID987654
MANDIRI_PARTNER_ID=PID-jstore-partner
MANDIRI_CHANNEL_ID=CH-qris-01

# Certificate/Keys Path
MANDIRI_PRIVATE_KEY_PATH=keys/mandiri_private.key
MANDIRI_PUBLIC_KEY_PATH=keys/mandiri_public.key
MANDIRI_WEBHOOK_SECRET=WH-secret-token

# Redirect and Callback URLs
MANDIRI_CALLBACK_URL=https://yourdomain.com/api/webhooks/mandiri
MANDIRI_RETURN_URL=https://yourdomain.com/dashboard/pesanan

# Timeouts & Expiration Configuration
MANDIRI_TIMEOUT_SECONDS=30
MANDIRI_QRIS_EXPIRY_MINUTES=15
